{
  "name": "zerotrust-desktop",
  "version": "1.0.0",
  "main": "electron/main.js",
  "homepage": "./",
  "description": "Zero-Trust Secure File Sharing Desktop Application",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "electron": "electron .",
    "vite": "vite",
    "build": "vite build && electron-builder",
    "dist": "npm run build",
    "preview": "vite preview",
    "test": "vitest",
    "lint": "eslint src --ext .js,.jsx"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.19.0",
    "axios": "^1.6.2",
    "crypto-js": "^4.2.0",
    "date-fns": "^2.30.0",
    "jotai": "^2.4.0",
    "lucide-react": "^0.294.0",
    "clsx": "^2.0.0",
    "electron-store": "^8.2.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.0",
    "vite": "^5.0.2",
    "electron": "^28.0.0",
    "electron-builder": "^24.7.0",
    "concurrently": "^8.2.0",
    "wait-on": "^7.0.1",
    "eslint": "^8.54.0",
    "vitest": "^1.0.0",
    "@testing-library/react": "^14.1.0"
  },
  "build": {
    "appId": "com.zerotrust.secure-share",
    "productName": "Zero-Trust Secure Share",
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "directories": {
      "buildResources": "assets"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
